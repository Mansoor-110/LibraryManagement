@model List<LibraryManagement.Models.Order>

<style>
    * {
        box-sizing: border-box;
    }

    .orders-wrap {
        background: #fff;
        padding: 40px 40px 80px;
    }

    .orders-list {
        display: flex;
        flex-direction: column;
        gap: 22px;
        max-width: 1100px;
        margin: 0 auto;
    }

    .order-card {
        border: 1px solid #eee;
        border-radius: 6px;
        overflow: hidden;
        background: #fff;
        transition: box-shadow 0.2s;
    }

        .order-card:hover {
            box-shadow: 0 8px 24px rgba(26,35,64,0.10);
        }

    .order-card-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 20px;
        padding: 16px 24px;
        background: #f8f9fb;
        border-bottom: 1px solid #f1f1f1;
        flex-wrap: wrap;
    }

    .order-header-block {
        display: flex;
        flex-direction: column;
        gap: 2px;
    }

    .order-header-label {
        font-size: 10px;
        letter-spacing: 0.5px;
        text-transform: uppercase;
        color: #888;
    }

    .order-header-value {
        font-size: 13px;
        font-weight: 700;
        color: #1a2340;
    }

    .status-badge {
        display: inline-block;
        font-size: 11px;
        font-weight: 700;
        letter-spacing: 0.5px;
        text-transform: uppercase;
        padding: 4px 10px;
        border-radius: 2px;
    }

        .status-badge.pending {
            background: #fff3cd;
            color: #b8860b;
        }

        .status-badge.delivered {
            background: #d4f7e0;
            color: #0d7a3f;
        }

        .status-badge.processing {
            background: #d6ecff;
            color: #0b5ed7;
        }

        .status-badge.cancelled {
            background: #fdecea;
            color: #c0392b;
        }

    .order-card-body {
        padding: 6px 24px;
    }

    .order-item-row {
        display: flex;
        align-items: center;
        gap: 14px;
        padding: 12px 0;
        border-bottom: 1px solid #f6f6f6;
    }

        .order-item-row:last-child {
            border-bottom: none;
        }

    .order-item-img {
        width: 54px;
        height: 54px;
        border-radius: 4px;
        background: #e8f4f8;
        overflow: hidden;
        flex-shrink: 0;
    }

        .order-item-img img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

    .order-item-info {
        flex: 1;
        min-width: 0;
    }

    .order-item-name {
        font-size: 14px;
        font-weight: 600;
        color: #1a2340;
    }

    .order-item-author {
        font-size: 12px;
        color: #888;
    }

    .order-item-qty {
        font-size: 12px;
        color: #666;
    }

    .order-item-price {
        font-size: 13px;
        font-weight: 700;
        color: #1a2340;
        white-space: nowrap;
    }

    .order-card-footer {
        display: flex;
        justify-content: flex-end;
        align-items: center;
        gap: 10px;
        padding: 14px 24px 18px;
        font-size: 15px;
        font-weight: 700;
        color: #1a2340;
    }

        .order-card-footer span.label {
            font-size: 12px;
            font-weight: 500;
            color: #888;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

    .orders-empty {
        text-align: center;
        padding: 80px 20px;
        max-width: 500px;
        margin: 0 auto;
    }

        .orders-empty p {
            font-size: 15px;
            color: #888;
            margin-bottom: 24px;
        }

    .cart-browse-btn {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        background: #1a2340;
        color: #fff;
        border: none;
        padding: 13px 26px;
        font-size: 14px;
        font-weight: 600;
        border-radius: 2px;
        text-decoration: none;
        transition: background 0.2s;
    }

        .cart-browse-btn:hover {
            background: #00bcd4;
        }

    @@media (max-width: 600px) {
        .orders-wrap {
            padding: 30px 20px;
        }

        .order-card-header {
            flex-direction: column;
            align-items: flex-start;
            gap: 10px;
        }
    }
</style>

<div class="text-center wow fadeInUp" data-wow-delay="0.1s">
    <h6 class="section-title bg-white text-center text-primary px-3">Orders</h6>
    <h1 class="mb-5">My Orders</h1>
</div>

<div class="orders-wrap">

    @if (!Model.Any())
    {
        <div class="orders-empty">
            <p>Aapne abhi tak koi order nahi kiya.</p>
            <a asp-action="Index" asp-controller="Home" class="cart-browse-btn">
                <i class="ti ti-arrow-left" aria-hidden="true"></i>
                Browse Books
            </a>
        </div>
    }
    else
    {
        <div class="orders-list">
            @foreach (var order in Model)
            {
                string statusClass = order.OrderStatus.ToLower() switch
                {
                    "delivered" => "delivered",
                    "processing" => "processing",
                    "cancelled" => "cancelled",
                    _ => "pending"
                };

                <div class="order-card">
                    <div class="order-card-header">
                        <div class="order-header-block">
                            <span class="order-header-label">Order Number</span>
                            <span class="order-header-value">#@order.OrderId.ToString("D5")</span>
                        </div>
                        <div class="order-header-block">
                            <span class="order-header-label">Placed On</span>
                            <span class="order-header-value">@order.CreatedAt.ToString("dd MMM yyyy")</span>
                        </div>
                        <div class="order-header-block">
                            <span class="order-header-label">Payment</span>
                            <span class="order-header-value">@order.PaymentMethod</span>
                        </div>
                        <div class="order-header-block">
                            <span class="order-header-label">Status</span>
                            <span class="status-badge @statusClass">@order.OrderStatus</span>
                        </div>
                    </div>

                    <div class="order-card-body">
                        @foreach (var item in order.OrderItems)
                        {
                            <div class="order-item-row">
                                <div class="order-item-img">
                                    <img src="~/BookImages/@item.BookImageName" alt="@item.BookName" />
                                </div>
                                <div class="order-item-info">
                                    <div class="order-item-name">@item.BookName</div>
                                    <div class="order-item-author">@item.BookAuthor</div>
                                    <div class="order-item-qty">Qty: @item.Quantity</div>
                                </div>
                                <div class="order-item-price">Rs.@(item.Price* item.Quantity)</div>
                            </div>
                        }
                    </div>

                    <div class="order-card-footer">
                        <span class="label">Total:</span>
                        <span>Rs.@order.TotalAmount</span>
                    </div>
                </div>
            }
        </div>
    }

</div>
