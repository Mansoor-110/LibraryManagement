@model LibraryManagement.Models.Book;
<style>
    * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
    }

    body {
        font-family: 'Segoe UI', sans-serif;
    }

    .page-wrap {
        background: #fff;
        padding: 40px 40px;
    }

    .section-label {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 12px;
        font-size: 12px;
        font-weight: 600;
        letter-spacing: 2px;
        color: #00bcd4;
        text-transform: uppercase;
        margin-bottom: 14px;
    }

        .section-label::before, .section-label::after {
            content: '';
            display: block;
            width: 40px;
            height: 2px;
            background: #00bcd4;
        }

    .section-title {
        text-align: center;
        font-size: 28px;
        font-weight: 700;
        color: #1a2340;
        margin-bottom: 50px;
    }

    .detail-grid {
        display: grid;
        grid-template-columns: 1fr 1.4fr;
        gap: 50px;
        max-width: 860px;
        margin: 0 auto;
        align-items:center;
    }

    .img-col {
        position: relative;
    }

    .main-img {
        width: 350px;
        border-radius: 4px;
        overflow: hidden;
        background: #e8f4f8;
        /* aspect-ratio: 3/4;  */
        display: flex;
        align-items: center;
        justify-content: center;
    }

        .main-img img {
            width: 100%;
            height: 100%;
        }

    .badge {
        position: absolute;
        top: 16px;
        left: 16px;
        background: #00bcd4;
        color: #fff;
        font-size: 11px;
        font-weight: 700;
        letter-spacing: 1px;
        text-transform: uppercase;
        padding: 5px 12px;
        border-radius: 2px;
    }

    .thumb-row {
        display: flex;
        gap: 10px;
        margin-top: 12px;
    }

    .thumb {
        flex: 1;
        aspect-ratio: 1;
        border-radius: 4px;
        overflow: hidden;
        background: #dce8f0;
        border: 2px solid transparent;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: border-color 0.2s;
    }

        .thumb.active {
            border-color: #00bcd4;
        }

        .thumb svg {
            width: 70%;
            height: 70%;
            opacity: 0.5;
        }

    .info-col {
        padding-top: 4px;
    }

    .book-category {
        font-size: 12px;
        font-weight: 600;
        color: #00bcd4;
        letter-spacing: 1.5px;
        text-transform: uppercase;
        margin-bottom: 10px;
    }

    .book-title {
        font-size: 26px;
        font-weight: 700;
        color: #1a2340;
        line-height: 1.3;
        margin-bottom: 10px;
    }

    .rating-row {
        display: flex;
        align-items: center;
        gap: 8px;
        margin-bottom: 16px;
    }

    .stars {
        color: #f5a623;
        font-size: 15px;
        letter-spacing: 1px;
    }

    .rating-text {
        font-size: 13px;
        color: #888;
    }

    .price-row {
        display: flex;
        align-items: baseline;
        gap: 12px;
        margin-bottom: 10px;
    }

    .price-now {
        font-size: 28px;
        font-weight: 700;
        color: #1a2340;
    }

    .price-old {
        font-size: 16px;
        color: #bbb;
        text-decoration: line-through;
    }

    .price-save {
        font-size: 12px;
        font-weight: 600;
        color: #00bcd4;
        background: #e0f7fa;
        padding: 3px 8px;
        border-radius: 2px;
    }

    .divider {
        border: none;
        border-top: 1px solid #eee;
        margin: 20px 0;
    }

    .desc {
        font-size: 14px;
        color: #555;
        line-height: 1.8;
        margin-bottom: 22px;
    }   

    .meta-list {
        list-style: none;
        margin-bottom: 24px;
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

        .meta-list li {
            display: flex;
            align-items: center;
            gap: 10px;
            font-size: 13px;
            color: #444;
        }

            .meta-list li span.label {
                color: #888;
                min-width: 80px;
                font-size: 12px;
                text-transform: uppercase;
                letter-spacing: 0.5px;
            }

    .meta-icon {
        color: #00bcd4;
        font-size: 16px;
    }

    .qty-row {
        display: flex;
        align-items: center;
        gap: 16px;
        margin-bottom: 22px;
    }

    .qty-label {
        font-size: 13px;
        color: #888;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        font-size: 12px;
    }

    .qty-ctrl {
        display: flex;
        align-items: center;
        border: 1px solid #ddd;
        border-radius: 2px;
        overflow: hidden;
    }

    .qty-btn {
        width: 34px;
        height: 34px;
        background: #f5f5f5;
        border: none;
        cursor: pointer;
        font-size: 18px;
        color: #1a2340;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: background 0.15s;
    }

        .qty-btn:hover {
            background: #e0f7fa;
            color: #00bcd4;
        }

    .qty-val {
        width: 40px;
        text-align: center;
        font-size: 14px;
        font-weight: 600;
        color: #1a2340;
    }

    .btn-row {
        display: flex;
        gap: 12px;
        margin-bottom: 22px;
    }

    .btn-primary {
        flex: 1;
        background: #00bcd4;
        color: #fff;
        border: none;
        padding: 13px 20px;
        font-size: 14px;
        font-weight: 600;
        letter-spacing: 0.5px;
        cursor: pointer;
        border-radius: 2px;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        transition: background 0.2s;
    }

    

        .btn-primary:hover {
            background: #0097a7;
        }

    .borrow-btn{
        flex: 1;
        background: #1a2340;
        color: #fff;
        border: none;
        padding: 13px 20px;
        font-size: 14px;
        font-weight: 600;
        letter-spacing: 0.5px;
        cursor: pointer;
        border-radius: 2px;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        transition: background 0.2s;
    }
    .borrow-btn:hover{
        background: transparent;
        color: #1a2340;
        border: 0.5px solid #1a2340;
        transition: all 0.2s;
    }

    .btn-outline {
        padding: 13px 18px;
        background: transparent;
        color: #1a2340;
        border: 1.5px solid #1a2340;
        font-size: 14px;
        font-weight: 600;
        cursor: pointer;
        border-radius: 2px;
        display: flex;
        align-items: center;
        gap: 6px;
        transition: all 0.2s;
    }

        .btn-outline:hover {
            background: #1a2340;
            color: #fff;
        }

    .btn-wishlist {
        width: 46px;
        height: 46px;
        background: transparent;
        border: 1.5px solid #ddd;
        border-radius: 2px;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #888;
        font-size: 18px;
        transition: all 0.2s;
    }

        .btn-wishlist:hover {
            border-color: #e91e63;
            color: #e91e63;
        }

    .tags-row {
        display: flex;
        align-items: center;
        gap: 8px;
        flex-wrap: wrap;
        margin-bottom: 0;
    }

    .tag-label {
        font-size: 12px;
        color: #888;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .tag {
        font-size: 12px;
        color: #1a2340;
        border: 1px solid #ddd;
        padding: 3px 10px;
        border-radius: 2px;
        cursor: pointer;
        transition: all 0.2s;
    }

        .tag:hover {
            border-color: #00bcd4;
            color: #00bcd4;
        }

    .share-row {
        display: flex;
        align-items: center;
        gap: 10px;
        margin-top: 14px;
    }

    .share-label {
        font-size: 12px;
        color: #888;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .social-btn {
        width: 32px;
        height: 32px;
        border: 1px solid #ddd;
        border-radius: 50%;
        background: transparent;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        color: #555;
        font-size: 14px;
        transition: all 0.2s;
    }

        .social-btn:hover {
            background: #00bcd4;
            border-color: #00bcd4;
            color: #fff;
        }

    .guarantee-strip {
        display: flex;
        gap: 20px;
        margin: 40px auto 0;
        max-width: 860px;
        border-top: 1px solid #eee;
        padding-top: 28px;
    }

    .guarantee-item {
        display: flex;
        align-items: flex-start;
        gap: 12px;
        flex: 1;
    }

    .g-icon {
        font-size: 26px;
        color: #00bcd4;
        flex-shrink: 0;
        margin-top: 2px;
    }

    .g-title {
        font-size: 13px;
        font-weight: 600;
        color: #1a2340;
        margin-bottom: 2px;
    }

    .g-text {
        font-size: 12px;
        color: #888;
        line-height: 1.5;
    }

    @@media (max-width: 600px) {
        .detail-grid {
            grid-template-columns: 1fr;
            gap: 30px;
        }

        .guarantee-strip {
            flex-direction: column;
            gap: 16px;
        }
    }
</style>


    <div class="text-center wow fadeInUp" data-wow-delay="0.1s">
        <h6 class="section-title bg-white text-center text-primary px-3">Books</h6>
        <h1 class="mb-5">Wide Range Of Books!</h1>
    </div>
    <div class="detail-grid">
        <!-- Left: image -->
        <div class="img-col">
            <div class="main-img">
              <img   src ="~/BookImages/@Model.BookImageName" >  
              
            </div>
            <span class="badge">Bestseller</span>
            
        </div>

        <!-- Right: info -->
        <div class="info-col">
            <h1 class="book-title">@Model.BookName</h1>

            <div class="rating-row">
                <span class="stars">★★★★★</span>
                <span class="rating-text">4.9 (238 reviews)</span>
            </div>

            <div class="price-row">
                <span class="price-now">Rs.@Model.BookPrice</span>
                
               @{
                  int price = Model.BookPrice;
                  double percent = 25;
                  int oldPrice = (int)(price + (price * percent / 100));
               }
                <span class="price-old"> @oldPrice</span>
                
                <span class="price-save">Save 25%</span>
            </div>

            <hr class="divider">

            <p class="desc">
              @Model.BookDescription
            </p>

            <ul class="meta-list">
                <li>
                    <i class="ti ti-user meta-icon" aria-hidden="true"></i>
                    <span class="label">Author</span>
                    <strong>@Model.BookAuthor</strong>
                </li>
                
                <li>
                    <i class="ti ti-file-text meta-icon" aria-hidden="true"></i>
                    <span class="label">Pages</span>
                 @Model.BookPages
                </li>
                <li>
                    <i class="ti ti-language meta-icon" aria-hidden="true"></i>
                    <span class="label">Language</span>
                    @Model.BookLanguage
                </li>
                <li>
                    <i class="ti ti-check meta-icon" aria-hidden="true"></i>
                    <span class="label">Stock</span>
                @if (Model.quantity > 0)
                {
                    
                    <span style="color:#00bcd4;font-weight:600;">In Stock</span>
                }
                else
                {
                    <span style="color:#00bcd4;font-weight:600;">Out OF Stock</span>
                    
                }
                
            </li>
            </ul>

            <div class="qty-row">
                <span class="qty-label">Quantity</span>
                <div class="qty-ctrl">
                    <button class="qty-btn" onclick="changeQty(-1)">−</button>
                    <span class="qty-val" id="qty" > 1</span>
                    <button class="qty-btn" onclick="changeQty(1)">+</button>
                </div>
            </div>

            <div class="btn-row">
                <button class="btn-primary">
                    <i class="ti ti-shopping-cart" aria-hidden="true"></i>
                    Add to Cart
                </button>
                <button class="btn-outline">
                    <i class="ti ti-bolt" aria-hidden="true"></i>
                    Buy Now
                </button>
                <button class="btn-wishlist" title="Add to wishlist">
                    <i class="ti ti-heart" aria-hidden="true"></i>
                </button>
            </div>

            <div class="btn-row">
            <button class="borrow-btn">
                <i class="ti ti-arrow-bear-left"></i>
                Borrow
            </button>
            </div>

            <hr class="divider">

            

           
        </div>
    </div>


<script>
    let qty = 1;

    function changeQty(d) {
      
      qty = Math.max(1, qty + d);
      document.getElementById('qty').textContent = qty;
    }
</script>
