@model LibraryManagement.Models.CheckoutVM

<style>
    * {
        box-sizing: border-box;
    }

    .checkout-wrap {
        background: #fff;
        padding: 40px 40px 80px;
    }

    .checkout-grid {
        display: grid;
        grid-template-columns: 1.4fr 1fr;
        gap: 40px;
        max-width: 1100px;
        margin: 0 auto;
        align-items: start;
    }

    /* ---- Left: delivery form ---- */
    .checkout-card {
        border: 1px solid #eee;
        border-radius: 6px;
        padding: 28px 30px;
        background: #fff;
    }

    .checkout-card-title {
        font-size: 17px;
        font-weight: 700;
        color: #1a2340;
        margin-bottom: 20px;
        display: flex;
        align-items: center;
        gap: 8px;
    }

        .checkout-card-title i {
            color: #00bcd4;
        }

    .form-group {
        margin-bottom: 18px;
    }

    .form-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 16px;
    }

    .form-label {
        display: block;
        font-size: 12px;
        font-weight: 600;
        letter-spacing: 0.5px;
        text-transform: uppercase;
        color: #888;
        margin-bottom: 8px;
    }

    .form-control {
        width: 100%;
        padding: 12px 14px;
        border: 1px solid #ddd;
        border-radius: 3px;
        font-size: 14px;
        color: #1a2340;
        transition: border-color 0.2s;
    }

        .form-control:focus {
            outline: none;
            border-color: #00bcd4;
        }

    .payment-note {
        display: flex;
        align-items: center;
        gap: 10px;
        background: #e0f7fa;
        border: 1px solid #b2ebf2;
        border-radius: 4px;
        padding: 12px 16px;
        font-size: 13px;
        color: #006064;
        margin-top: 6px;
    }

        .payment-note i {
            color: #00bcd4;
            font-size: 18px;
        }

    /* ---- Right: order summary ---- */
    .summary-card {
        border: 1px solid #eee;
        border-radius: 6px;
        background: #fff;
        position: sticky;
        top: 20px;
    }

    .summary-title {
        font-size: 17px;
        font-weight: 700;
        color: #1a2340;
        padding: 22px 24px 16px;
        border-bottom: 1px solid #f1f1f1;
    }

    .summary-items {
        max-height: 320px;
        overflow-y: auto;
        padding: 0 24px;
    }

    .summary-item {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 14px 0;
        border-bottom: 1px solid #f6f6f6;
    }

        .summary-item:last-child {
            border-bottom: none;
        }

    .summary-item-img {
        width: 50px;
        height: 50px;
        border-radius: 4px;
        background: #e8f4f8;
        overflow: hidden;
        flex-shrink: 0;
    }

        .summary-item-img img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

    .summary-item-info {
        flex: 1;
        min-width: 0;
    }

    .summary-item-name {
        font-size: 13px;
        font-weight: 600;
        color: #1a2340;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .summary-item-qty {
        font-size: 12px;
        color: #888;
    }

    .summary-item-price {
        font-size: 13px;
        font-weight: 700;
        color: #1a2340;
        white-space: nowrap;
    }

    .summary-totals {
        padding: 18px 24px 24px;
    }

    .summary-row {
        display: flex;
        justify-content: space-between;
        font-size: 13px;
        color: #666;
        margin-bottom: 10px;
    }

        .summary-row.grand-total {
            font-size: 17px;
            font-weight: 700;
            color: #1a2340;
            border-top: 1px solid #f1f1f1;
            padding-top: 14px;
            margin-top: 4px;
            margin-bottom: 20px;
        }

    .place-order-btn {
        width: 100%;
        padding: 14px;
        background: #00bcd4;
        color: #fff;
        border: none;
        font-size: 14px;
        font-weight: 600;
        letter-spacing: 0.5px;
        cursor: pointer;
        border-radius: 3px;
        transition: background 0.2s;
    }

        .place-order-btn:hover {
            background: #0097a7;
        }

    @@media (max-width: 800px) {
        .checkout-grid {
            grid-template-columns: 1fr;
        }

        .form-row {
            grid-template-columns: 1fr;
        }

        .summary-card {
            position: static;
        }
    }

    @@media (max-width: 600px) {
        .checkout-wrap {
            padding: 30px 20px;
        }
    }
</style>

@if (TempData["ErrorMessage"] != null)
{
    <div class="container mt-3">
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    </div>
}

<div class="text-center wow fadeInUp" data-wow-delay="0.1s">
    <h6 class="section-title bg-white text-center text-primary px-3">Checkout</h6>
    <h1 class="mb-5">Delivery Details</h1>
</div>

<div class="checkout-wrap">
    <form asp-action="PlaceOrder" asp-controller="Home" method="post">
        <div class="checkout-grid">

            <!-- Left: delivery form -->
            <div class="checkout-card">
                <div class="checkout-card-title">
                    <i class="ti ti-truck" aria-hidden="true"></i>
                    Delivery Information
                </div>

                <div class="form-group">
                    <label class="form-label">Full Name</label>
                    <input type="text" name="FullName" class="form-control" placeholder="Your full name" required />
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label class="form-label">Phone Number</label>
                        <input type="text" name="Phone" class="form-control" placeholder="03XX-XXXXXXX" required />
                    </div>
                    <div class="form-group">
                        <label class="form-label">City</label>
                        <input type="text" name="City" class="form-control" placeholder="Your city" required />
                    </div>
                </div>

                <div class="form-group">
                    <label class="form-label">Full Address</label>
                    <input type="text" name="Address" class="form-control" placeholder="House #, Street, Area" required />
                </div>

                <div class="payment-note">
                    <i class="ti ti-cash" aria-hidden="true"></i>
                    Payment Method: <strong>&nbsp;Cash on Delivery</strong>
                </div>
            </div>

            <!-- Right: order summary -->
            <div class="summary-card">
                <div class="summary-title">Order Summary</div>

                <div class="summary-items">
                    @foreach (var item in Model.CartItems)
                    {
                        <div class="summary-item">
                            <div class="summary-item-img">
                                <img src="~/BookImages/@item.BookImageName" alt="@item.BookName" />
                            </div>
                            <div class="summary-item-info">
                                <div class="summary-item-name">@item.BookName</div>
                                <div class="summary-item-qty">Qty: @item.Quantity</div>
                            </div>
                            <div class="summary-item-price">Rs.@(item.BookPrice* item.Quantity)</div>
                        </div>
                    }
                </div>

                <div class="summary-totals">
                    <div class="summary-row">
                        <span>Subtotal</span>
                        <span>Rs.@Model.TotalAmount</span>
                    </div>
                    <div class="summary-row">
                        <span>Delivery Charges</span>
                        <span>Free</span>
                    </div>
                    <div class="summary-row grand-total">
                        <span>Total</span>
                        <span>Rs.@Model.TotalAmount</span>
                    </div>

                    <button type="submit" class="place-order-btn">Place Order</button>
                </div>
            </div>

        </div>
    </form>
</div>
