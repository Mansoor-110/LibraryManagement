@model LibraryManagement.Models.ProfileVM
@{
    string initials = "";
    if (!string.IsNullOrWhiteSpace(Model.UserName))
    {
        var parts = Model.UserName.Trim().Split(' ', StringSplitOptions.RemoveEmptyEntries);
        initials = parts.Length >= 2
            ? $"{parts[0][0]}{parts[1][0]}".ToUpper()
            : parts[0].Substring(0, Math.Min(2, parts[0].Length)).ToUpper();
    }
    string[] coverClasses = { "cover-1", "cover-2", "cover-3" };
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>My Profile — eLEARNING</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        :root {
            --teal: #1cb8ba;
            --teal-dark: #149193;
            --teal-tint: #eafcfc;
            --navy: #14213d;
            --gray: #6f7c8e;
            --amber: #f2994a;
            --amber-tint: #fff4e8;
            --red: #e0575b;
            --red-tint: #fdeceb;
            --radius: 10px;
            --shadow: 0 10px 30px rgba(20,33,61,0.08);
        }

        * {
            box-sizing: border-box;
        }

        body {
            margin: 0;
            font-family: 'Poppins',sans-serif;
            color: var(--navy);
            background: #ffffff;
        }

        .container {
            max-width: 1140px;
            margin: 0 auto;
            padding: 0 20px;
        }

        a {
            text-decoration: none;
        }





        section {
            padding: 64px 0;
        }

            section + section {
                border-top: 1px solid #eef1f6;
            }

        /* ---------- profile hero ---------- */
        .profile-card {
            display: flex;
            align-items: center;
            gap: 26px;
            background: var(--teal-tint);
            border-radius: var(--radius);
            padding: 30px 34px;
            margin-bottom: 26px;
            flex-wrap: wrap;
        }

        .avatar {
            width: 84px;
            height: 84px;
            border-radius: 50%;
            background: var(--teal);
            color: #fff;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 32px;
            font-weight: 600;
            flex: none;
        }

        .profile-info h2 {
            margin: 0 0 4px;
            font-size: 24px;
            font-weight: 700;
        }

        .profile-info p {
            margin: 0 0 3px;
            color: var(--gray);
            font-size: 14.5px;
            display: flex;
            align-items: center;
            gap: 8px;
        }

            .profile-info p i {
                color: var(--teal);
                width: 14px;
            }

        .stat-row {
            display: grid;
            grid-template-columns: repeat(3,1fr);
            gap: 24px;
        }

        .stat-card {
           
            /* border: 1px solid #eef1f6; */
            border-radius: var(--radius);
            /* box-shadow: var(--shadow); */
            padding: 26px 24px;
            text-align: center;
            transition: transform .25s ease, box-shadow .25s ease;
        }

            .stat-card:hover {
                transform: translateY(-4px);
                box-shadow: 0 16px 34px rgba(20,33,61,.12);
            }

        .stat-icon {
            width: 54px;
            height: 54px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 16px;
            font-size: 20px;
            background: var(--teal-tint);
            color: var(--teal);
        }

        .stat-card.fine .stat-icon {
            background: var(--amber-tint);
            color: var(--amber);
        }

        .stat-value {
            font-size: 26px;
            font-weight: 700;
            margin-bottom: 4px;
        }

        .stat-card.fine .stat-value {
            color: var(--amber);
        }

        .stat-label {
            color: var(--gray);
            font-size: 13.5px;
        }

        .stat-sub {
            color: var(--gray);
            font-size: 12px;
            margin-top: 6px;
        }

        .pay-btn {
            display: inline-block;
            margin-top: 14px;
            background: var(--amber);
            color: #fff;
            font-size: 13px;
            font-weight: 600;
            padding: 8px 20px;
            border-radius: 4px;
            transition: background .2s ease;
        }

            .pay-btn:hover {
                background: #e0863a;
                color: #fff;
            }

        /* ---------- issued books cards ---------- */
        .book-grid {
            display: grid;
            grid-template-columns: repeat(3,1fr);
            gap: 26px;
        }

        .book-card {
            border: 1px solid #eef1f6;
            border-radius: var(--radius);
            overflow: hidden;
            box-shadow: var(--shadow);
            background: #fff;
            transition: transform .25s ease, box-shadow .25s ease;
        }

            .book-card:hover {
                transform: translateY(-5px);
                box-shadow: 0 16px 34px rgba(20,33,61,.12);
            }

        .book-cover {
            height: 140px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 34px;
            color: #fff;
            position: relative;
        }

            .book-cover i {
                opacity: .9;
            }

        .cover-1 {
            background: linear-gradient(135deg,#1cb8ba,#0d7f80);
        }

        .cover-2 {
            background: linear-gradient(135deg,#2c3e63,#14213d);
        }

        .cover-3 {
            background: linear-gradient(135deg,#3fd0c9,#1a9c96);
        }

        .status-chip {
            position: absolute;
            top: 12px;
            right: 12px;
            font-size: 11px;
            font-weight: 600;
            padding: 4px 10px;
            border-radius: 20px;
            text-transform: uppercase;
            letter-spacing: .4px;
        }

        .chip-ontime {
            background: #fff;
            color: var(--teal);
        }

        .chip-overdue {
            background: #fff;
            color: var(--red);
        }

        .book-body {
            padding: 20px;
        }

        .book-title {
            font-size: 16px;
            font-weight: 600;
            margin: 0 0 4px;
        }

        .book-author {
            font-size: 13px;
            color: var(--gray);
            margin: 0 0 14px;
        }

        .book-meta {
            display: flex;
            justify-content: space-between;
            font-size: 12.5px;
            color: var(--gray);
            border-top: 1px solid #f0f2f6;
            padding-top: 12px;
        }

            .book-meta span i {
                color: var(--teal);
                margin-right: 5px;
            }

        .book-fine-note {
            margin-top: 10px;
            font-size: 12px;
            color: var(--red);
            font-weight: 500;
        }

        /* ---------- tables (requests / history) ---------- */
        .table-card {
            border: 1px solid #eef1f6;
            border-radius: var(--radius);
            box-shadow: var(--shadow);
            overflow: hidden;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            font-size: 14px;
        }

        thead tr {
            background: var(--teal-tint);
        }

        th {
            text-align: left;
            padding: 16px 20px;
            font-size: 12.5px;
            text-transform: uppercase;
            letter-spacing: .5px;
            color: var(--navy);
            font-weight: 600;
        }

        td {
            padding: 16px 20px;
            border-top: 1px solid #f0f2f6;
            color: var(--navy);
            vertical-align: middle;
        }

            td.book-cell {
                font-weight: 500;
            }

            td.muted, .muted {
                color: var(--gray);
            }

        .badge-pill {
            display: inline-block;
            font-size: 12px;
            font-weight: 600;
            padding: 5px 14px;
            border-radius: 20px;
        }

        .badge-pending {
            background: var(--amber-tint);
            color: var(--amber);
        }

        .badge-approved {
            background: var(--teal-tint);
            color: var(--teal-dark);
        }

        .badge-rejected {
            background: var(--red-tint);
            color: var(--red);
        }

        .badge-ontime {
            background: var(--teal-tint);
            color: var(--teal-dark);
        }

        .badge-late {
            background: var(--red-tint);
            color: var(--red);
        }

        /* ---------- responsive ---------- */
        @@media (max-width:900px) {
            .stat-row {
                grid-template-columns: 1fr;
            }

            .book-grid {
                grid-template-columns: 1fr 1fr;
            }
        }

        @@media (max-width:640px) {
            .book-grid {
                grid-template-columns: 1fr;
            }

            .profile-card {
                text-align: center;
                justify-content: center;
            }

            table {
                font-size: 13px;
            }
            

            th, td {
                padding: 12px 10px;
            }
        }
    </style>
</head>
<body>

    <div class="profile-page">

        <!-- ============ PROFILE OVERVIEW ============ -->
        <section>
            <div class="container">
                @if (TempData["SuccessMessage"] != null)
                {
                    <div class="alert alert-success alert-dismissible fade show" role="alert">
                        @TempData["SuccessMessage"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                }
                @if (TempData["ErrorMessage"] != null)
                {
                    <div class="alert alert-danger alert-dismissible fade show" role="alert">
                        @TempData["ErrorMessage"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                }

                <div class="text-center wow fadeInUp" data-wow-delay="0.1s">
                    <h6 class="section-title bg-white text-center text-primary px-3">Dashboard</h6>
                    <h1 class="mb-5">My Profile</h1>
                </div>

                <div class="profile-card">
                    <div class="avatar">@initials</div>
                    <div class="profile-info">
                        <h2>@Model.UserName</h2>
                        <p><i class="fa-solid fa-envelope"></i> @Model.Email</p>
                        <p><i class="fa-solid fa-id-card"></i> Student ID: @Model.UserId</p>
                        <p><i class="fa-solid fa-calendar"></i> Member since @Model.MemberSince.ToString("MMM yyyy")</p>
                    </div>
                      <div class="stat-row mb-3 cwo">
                    <div class="stat-card ">
                        <div class="stat-icon">  <i class="fas fa-shopping-cart text-primary"></i></div>
                            <div class="stat-value"><a asp-action="Cart" asp-controller="Home" class="btn btn-outline-primary">View Cart</a></div>

                    </div>
                    <div class="stat-card">
                        <div class="stat-icon"><i class="fas fa-heart"></i></div>
                            <div class="stat-value"><a asp-action="Wishlist" asp-controller="Home" class="btn btn-outline-primary">View Wishlist</a></div>

                    </div>
                   
                    <div class="stat-card">
                        <div class="stat-icon"> <i class="fas fa-box text-primary"></i></div>
                        <div class="stat-value"><a asp-action="MyOrders" asp-controller="Home" class="btn btn-outline-primary">View Your Orders</a></div>

                    </div>
                   
                </div>
                </div>
                
               
                <div class="stat-row">
                    <div class="stat-card fine">
                        <div class="stat-icon"><i class="fa-solid fa-coins"></i></div>
                        <div class="stat-value">Rs. @Model.OutstandingFine</div>
                        <div class="stat-label">Outstanding Fine</div>
                        @if (Model.OutstandingFine > 0)
                        {
                            <a href="#" class="pay-btn">Pay Now</a>
                        }
                    </div>
                    <div class="stat-card">
                        <div class="stat-icon"><i class="fa-solid fa-book"></i></div>
                        <div class="stat-value">@Model.BooksCurrentlyIssuedCount</div>
                        <div class="stat-label">Books Currently Issued</div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-icon"><i class="fa-solid fa-clock-rotate-left"></i></div>
                        <div class="stat-value">@Model.PendingRequestsCount</div>
                        <div class="stat-label">Pending Borrow Request@(Model.PendingRequestsCount == 1 ? "" : "s")</div>
                    </div>
                </div>
            </div>
        </section>

        <!-- ============ ISSUED BOOKS ============ -->
        <section>
            <div class="container">
                <div class="text-center wow fadeInUp" data-wow-delay="0.1s">
                    <h6 class="section-title bg-white text-center text-primary px-3">Library</h6>
                    <h1 class="mb-5">Issued Books</h1>
                </div>

                @if (!Model.IssuedBooks.Any())
                {
                    <p class="text-center muted">Abhi koi book issued nahi hai.</p>
                }
                else
                {
                    <div class="book-grid">
                        @for (int i = 0; i < Model.IssuedBooks.Count; i++)
                        {
                            var book = Model.IssuedBooks[i];
                            var coverClass = coverClasses[i % coverClasses.Length];

                            <div class="book-card">
                                <div class="book-cover @coverClass">
                                    <img src="~/BookImages/@book.BookImageName" alt="@book.BookName"
                                         style="width:100%; height:100%; object-fit:cover; position:absolute; top:0; left:0;" />
                                    <span class="status-chip @(book.IsOverdue ? "chip-overdue" : "chip-ontime")">
                                        @(book.IsOverdue ? "Overdue" : "On Time")
                                    </span>
                                </div>
                                <div class="book-body">
                                    <p class="book-title">@book.BookName</p>
                                    <p class="book-author">@book.BookAuthor</p>
                                    <div class="book-meta">
                                        <span><i class="fa-regular fa-calendar-check"></i>Issued @book.IssuedDate.ToString("MMM d")</span>
                                        <span><i class="fa-regular fa-clock"></i>Due @book.DueDate.ToString("MMM d")</span>
                                    </div>
                                    @if (book.IsOverdue)
                                    {
                                        <p class="book-fine-note">@book.DaysOverdue day(s) overdue — Rs. @book.CurrentFine fine accruing</p>
                                    }

                                    <form asp-action="ReturnBook" asp-controller="Home" asp-route-id="@book.IssuedBookId" method="post" style="margin-top:12px;">
                                        <button type="submit" class="pay-btn" style="background:var(--teal); width:100%; border:none; cursor:pointer;">
                                            Return Book
                                        </button>
                                    </form>
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>
        </section>

        <!-- ============ BORROW REQUESTS ============ -->
        <section>
            <div class="container">
                <div class="text-center wow fadeInUp" data-wow-delay="0.1s">
                    <h6 class="section-title bg-white text-center text-primary px-3">Requests</h6>
                    <h1 class="mb-5">Borrow Requests</h1>
                </div>

                @if (!Model.BorrowRequests.Any())
                {
                    <p class="text-center muted">Koi borrow request nahi mili.</p>
                }
                else
                {
                    <div class="table-card">
                        <table>
                            <thead>
                                <tr>
                                    <th>Book</th>
                                    <th>Requested On</th>
                                    <th>Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var req in Model.BorrowRequests)
                                {
                                    string badgeClass = req.Status switch
                                    {
                                        "Pending" => "badge-pending",
                                        "Approved" => "badge-approved",
                                        "Rejected" => "badge-rejected",
                                        _ => "badge-pending"
                                    };

                                    <tr>
                                        <td class="book-cell">@req.BookName</td>
                                        <td class="muted">@req.RequestedOn.ToString("MMM d, yyyy")</td>
                                        <td><span class="badge-pill @badgeClass">@req.Status</span></td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </section>

        <!-- ============ HISTORY ============ -->
        <section>
            <div class="container">
                <div class="text-center wow fadeInUp" data-wow-delay="0.1s">
                    <h6 class="section-title bg-white text-center text-primary px-3">History</h6>
                    <h1 class="mb-5">Borrowing History</h1>
                </div>

                @if (!Model.History.Any())
                {
                    <p class="text-center muted">Abhi koi borrowing history nahi hai.</p>
                }
                else
                {
                    <div class="table-card">
                        <table>
                            <thead>
                                <tr>
                                    <th>Book</th>
                                    <th>Issued</th>
                                    <th>Returned</th>
                                    <th>Fine Paid</th>
                                    <th>Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var row in Model.History)
                                {
                                    <tr>
                                        <td class="book-cell">@row.BookName</td>
                                        <td class="muted">@row.IssuedDate.ToString("MMM d, yyyy")</td>
                                        <td class="muted">@(row.ReturnedDate?.ToString("MMM d, yyyy") ?? "-")</td>
                                        <td class="muted">Rs. @row.FinePaid</td>
                                        <td>
                                            @if (row.ReturnedLate)
                                            {
                                                <span class="badge-pill badge-late">Returned Late</span>
                                            }
                                            else
                                            {
                                                <span class="badge-pill badge-ontime">Returned On Time</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </section>

    </div>

</body>
</html>
