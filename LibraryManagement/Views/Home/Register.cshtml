@{
    Layout = null;
    
}
@model User;
    
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
<style>
    .register-wrapper {
        min-height: 80vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 60px 16px;
        background: #f5f7fa;
    }

    .register-card {
        background: #fff;
        border-radius: 10px;
        box-shadow: 0 8px 30px rgba(0,0,0,0.08);
        padding: 40px 36px;
        width: 100%;
        max-width: 480px;
    }

        .register-card .card-header {
            background: none;
            border: none;
            text-align: center;
            margin-bottom: 26px;
            padding: 0;
        }

            .register-card .card-header h2 {
                font-size: 22px;
                font-weight: 700;
                color: #1a1a2e;
                margin-bottom: 5px;
            }

            .register-card .card-header p {
                font-size: 13px;
                color: #999;
                margin: 0;
            }

        .register-card .accent-line {
            width: 44px;
            height: 3px;
            background: #1abdb5;
            border-radius: 2px;
            margin: 10px auto 0;
        }

    .register-form-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 12px;
    }

    .register-form-group {
        margin-bottom: 16px;
    }

        .register-form-group label {
            display: block;
            font-size: 12px;
            font-weight: 600;
            color: #555;
            margin-bottom: 6px;
        }

    .register-input-wrap {
        position: relative;
    }

        .register-input-wrap i.icon {
            position: absolute;
            left: 12px;
            top: 50%;
            transform: translateY(-50%);
            color: #c5c5c5;
            font-size: 13px;
            pointer-events: none;
        }

        .register-input-wrap input {
            width: 100%;
            padding: 10px 38px;
            border: 1.5px solid #e8e8e8;
            border-radius: 6px;
            font-size: 13px;
            font-family: inherit;
            color: #333;
            background: #fafafa;
            outline: none;
            transition: border-color 0.25s, background 0.25s, box-shadow 0.25s;
        }

            .register-input-wrap input:focus {
                border-color: #1abdb5;
                background: #fff;
                box-shadow: 0 0 0 3px rgba(26,189,181,0.1);
            }

            .register-input-wrap input::placeholder {
                color: #c8c8c8;
            }

            .register-input-wrap input.error {
                border-color: #e24b4a;
            }

            .register-input-wrap input.valid {
                border-color: #1abdb5;
            }

    .register-toggle-eye {
        position: absolute;
        right: 11px;
        top: 50%;
        transform: translateY(-50%);
        color: #c5c5c5;
        font-size: 13px;
        cursor: pointer;
        transition: color 0.2s;
    }

        .register-toggle-eye:hover {
            color: #1abdb5;
        }

    .register-strength-bar {
        display: flex;
        gap: 4px;
        margin-top: 6px;
    }

    .register-strength-seg {
        height: 3px;
        flex: 1;
        border-radius: 2px;
        background: #eee;
        transition: background 0.3s;
    }

    .register-hint {
        font-size: 11px;
        color: #aaa;
        margin-top: 4px;
        min-height: 16px;
    }

    .register-terms-row {
        display: flex;
        align-items: flex-start;
        gap: 8px;
        margin-bottom: 20px;
    }

        .register-terms-row input[type="checkbox"] {
            accent-color: #1abdb5;
            margin-top: 3px;
            cursor: pointer;
            flex-shrink: 0;
        }

        .register-terms-row label {
            font-size: 12px;
            color: #777;
            line-height: 1.6;
            cursor: pointer;
            margin: 0;
        }

            .register-terms-row label a {
                color: #1abdb5;
                text-decoration: none;
                font-weight: 600;
            }

                .register-terms-row label a:hover {
                    text-decoration: underline;
                }

    .register-submit-btn {
        width: 100%;
        padding: 12px;
        background: #1abdb5;
        color: #fff;
        border: none;
        border-radius: 6px;
        font-size: 14px;
        font-weight: 700;
        font-family: inherit;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        transition: background 0.2s, transform 0.1s;
    }

        .register-submit-btn:hover {
            background: #17a8a0;
        }

        .register-submit-btn:active {
            transform: scale(0.99);
        }

    .register-divider {
        display: flex;
        align-items: center;
        gap: 10px;
        margin: 18px 0;
    }

        .register-divider::before,
        .register-divider::after {
            content: '';
            flex: 1;
            height: 1px;
            background: #eee;
        }

        .register-divider span {
            font-size: 11px;
            color: #bbb;
            white-space: nowrap;
        }

    .register-social-row {
        display: flex;
        gap: 10px;
    }

    .register-social-btn {
        flex: 1;
        padding: 9px 6px;
        border: 1.5px solid #e8e8e8;
        border-radius: 6px;
        background: #fff;
        cursor: pointer;
        font-size: 13px;
        font-family: inherit;
        font-weight: 500;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 7px;
        color: #555;
        transition: border-color 0.2s, background 0.2s;
        white-space: nowrap;
    }

        .register-social-btn:hover {
            border-color: #1abdb5;
            background: #f0fffe;
        }

    .register-fb {
        color: #1877f2;
    }

    .register-ggl {
        color: #ea4335;
    }

    .register-login-link {
        text-align: center;
        margin-top: 18px;
        font-size: 12.5px;
        color: #888;
    }

        .register-login-link a {
            color: #1abdb5;
            font-weight: 600;
            text-decoration: none;
        }

            .register-login-link a:hover {
                text-decoration: underline;
            }

    @@media (max-width: 480px) {
        .register-form-row {
            grid-template-columns: 1fr;
        }

        .register-card {
            padding: 28px 18px;
        }
    }
</style>

<div class="register-wrapper">
    <div class="register-card">

        <div class="card-header">
            <h2>Create Your Account</h2>
            <p>Join thousands of learners on eLEARNING</p>
            <div class="accent-line"></div>
        </div>

        <form  asp-action="Register" asp-controller="Home" method="post">

            <div class="register-form-group">
                <label aspfor="fname">Name</label>
                <div class="register-input-wrap">
                    <i class="fas fa-user icon"></i>
                    <input type="text" id="fname" asp-for="User_name" placeholder="John" />
                </div>

            
        </div>

        <div class="register-form-group">
            <label for="email">Email Address</label>
            <div class="register-input-wrap">
                <i class="fas fa-envelope icon"></i>
                <input type="email" asp-for="Email" id="email" placeholder="you@example.com" />
            </div>
        </div>

        <div class="register-form-group">
            <label for="password">Password</label>
            <div class="register-input-wrap">
                <i class="fas fa-lock icon"></i>
                <input type="password" id="password" asp-for="Password" placeholder="Create a strong password" oninput="checkStrength(this.value)" />
                <i class="fas fa-eye register-toggle-eye" onclick="togglePwd('password', this)"></i>
            </div>
            <div class="register-strength-bar">
                <div class="register-strength-seg" id="s1"></div>
                <div class="register-strength-seg" id="s2"></div>
                <div class="register-strength-seg" id="s3"></div>
                <div class="register-strength-seg" id="s4"></div>
            </div>
            <div class="register-hint" id="slabel"></div>
        </div>

        <div class="register-form-group">
            <label for="confirm">Confirm Password</label>
            <div class="register-input-wrap">
                <i class="fas fa-lock icon"></i>
                <input type="password" id="confirm" asp-for="ConfirmPassword" placeholder="Re-enter your password" oninput="checkMatch()" />
                <i class="fas fa-eye register-toggle-eye" onclick="togglePwd('confirm', this)"></i>
            </div>
            <div class="register-hint" id="matchlabel"></div>
        </div>

        <div class="register-terms-row">
            <input type="checkbox" id="terms" />
            <label for="terms">I agree to the <a href="#">Terms &amp; Conditions</a> and <a href="#">Privacy Policy</a></label>
        </div>

        <input class="register-submit-btn" type="submit" value="Create Account">
           
       

        <div class="register-divider"><span>or sign up with</span></div>
        <div class="register-social-row">
            <button class="register-social-btn"><i class="fab fa-facebook-f register-fb"></i> Facebook</button>
            <button class="register-social-btn"><i class="fab fa-google register-ggl"></i> Google</button>
        </div>

        <div class="register-login-link">Already have an account? <a asp-action="Login">Login</a></div>

        </form>
    </div>
</div>

<script>
    function togglePwd(id, icon) {
      const inp = document.getElementById(id);
      inp.type = inp.type === 'password' ? 'text' : 'password';
      icon.classList.toggle('fa-eye');
      icon.classList.toggle('fa-eye-slash');
    }

    function checkStrength(val) {
      const segs = ['s1','s2','s3','s4'].map(id => document.getElementById(id));
      const label = document.getElementById('slabel');
      let score = 0;
      if (val.length >= 8) score++;
      if (/[A-Z]/.test(val)) score++;
      if (/[0-9]/.test(val)) score++;
      if (/[^A-Za-z0-9]/.test(val)) score++;
      const colors = ['#e24b4a','#ef9f27','#f0c330','#1abdb5'];
      const labels = ['','Weak','Fair','Good','Strong'];
      segs.forEach((s, i) => s.style.background = i < score ? colors[score-1] : '#eee');
      label.textContent = val.length ? labels[score] : '';
      label.style.color = score > 0 ? colors[score-1] : '#aaa';
      checkMatch();
    }

    function checkMatch() {
      const pwd = document.getElementById('password').value;
      const conf = document.getElementById('confirm').value;
      const confInput = document.getElementById('confirm');
      const lbl = document.getElementById('matchlabel');
      if (!conf) { lbl.textContent = ''; confInput.className = ''; return; }
      if (pwd === conf) {
        lbl.textContent = '✓ Passwords match';
        lbl.style.color = '#1abdb5';
        confInput.className = 'valid';
      } else {
        lbl.textContent = '✗ Passwords do not match';
        lbl.style.color = '#e24b4a';
        confInput.className = 'error';
      }
    }

    function handleSubmit() {
      const fname = document.getElementById('fname').value.trim();
      const email = document.getElementById('email').value.trim();
      const pwd = document.getElementById('password').value;
      const conf = document.getElementById('confirm').value;
      const terms = document.getElementById('terms').checked;
      if (!fname || !email || !pwd || !conf) { alert('Please fill in all fields.'); return; }
      if (pwd !== conf) { alert('Passwords do not match.'); return; }
      if (!terms) { alert('Please accept the Terms & Conditions.'); return; }
      alert('Account created successfully! Welcome to eLEARNING 🎓');
    }
</script>
