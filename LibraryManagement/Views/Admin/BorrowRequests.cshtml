@model List<LibraryManagement.Models.BorrowRequestVM>

@{
    Layout = "~/views/shared/_adminLayout.cshtml";
}
<!--**********************************
           Content body start
       ***********************************-->
<div class="content-body">
    <div class="container-fluid">
        <div class="row page-titles mx-0">
            <div class="col-sm-6 p-md-0">
                <div class="welcome-text">
                    <h4>Borrow Requests</h4>
                    <p class="mb-0">All book borrow requests submitted by users</p>
                </div>
            </div>
            <div class="col-sm-6 p-md-0 justify-content-sm-end mt-2 mt-sm-0 d-flex">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="javascript:void(0)">Table</a></li>
                    <li class="breadcrumb-item active"><a href="javascript:void(0)">Borrow Requests</a></li>
                </ol>
            </div>
        </div>
        <!-- row -->

        <div class="row">
            <div class="col-lg-12">
                <div class="card">
                    <div class="card-header">
                        <h4 class="card-title">Borrow Requests' Data</h4>
                    </div>
                    <div class="card-body">
                        <div class="table-responsive">
                            <table class="table primary-table-bordered table-responsive-sm text-muted">
                                <thead class="thead-primary">
                                    <tr class="text-primary">
                                        <th>Book</th>
                                        <th>Requested By</th>
                                        <th>Email</th>
                                        <th>Available Qty</th>
                                        <th>Requested On</th>
                                        <th>Status</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @if (!Model.Any())
                                    {
                                        <tr>
                                            <td colspan="6" class="text-center text-muted">No borrow requests yet.</td>
                                        </tr>
                                    }
                                    else
                                    {
                                        @foreach (var item in Model)
                                        {
                                            string badgeClass = item.Status.ToLower() switch
                                            {
                                                "approved" => "badge-success",
                                                "rejected" => "badge-danger",
                                                _ => "badge-warning"
                                            };
                                            <tr>
                                                <td class="d-flex align-items-center">
                                                    <img src="~/BookImages/@item.BookImageName" alt="@item.BookName" width="40" height="40" style="object-fit:cover;border-radius:4px;margin-right:10px;" />
                                                    @item.BookName
                                                </td>
                                                <td>@item.User_name</td>
                                                <td>@item.Email</td>
                                                <td>@item.qtyforborrow</td>
                                                <td>@item.CreatedAt.ToString("dd-MMM-yy")</td>
                                                <td><span class="badge @badgeClass">@item.Status</span></td>
                                            </tr>
                                        }
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
<!--**********************************
    Content body end
***********************************-->
