@model LibraryManagement.Models.DashboardVM

@{
    Layout = "~/views/shared/_adminLayout.cshtml";
}
<!--**********************************
    Content body start
***********************************-->
<div class="content-body">
    <!-- row -->
    <div class="container-fluid">

        <!-- Top stat cards -->
        <div class="row">
            <div class="col-lg-3 col-sm-6">
                <div class="card">
                    <div class="stat-widget-two card-body">
                        <div class="stat-content">
                            <div class="stat-text">Total Users</div>
                            <div class="stat-digit"><i class="fa fa-users"></i> @Model.TotalUsers</div>
                        </div>
                        <div class="progress">
                            <div class="progress-bar progress-bar-primary w-100" role="progressbar" aria-valuenow="100" aria-valuemin="0" aria-valuemax="100"></div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-lg-3 col-sm-6">
                <div class="card">
                    <div class="stat-widget-two card-body">
                        <div class="stat-content">
                            <div class="stat-text">Total Books</div>
                            <div class="stat-digit"><i class="fa fa-book"></i> @Model.TotalBooks</div>
                        </div>
                        <div class="progress">
                            <div class="progress-bar progress-bar-success w-100" role="progressbar" aria-valuenow="100" aria-valuemin="0" aria-valuemax="100"></div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-lg-3 col-sm-6">
                <div class="card">
                    <div class="stat-widget-two card-body">
                        <div class="stat-content">
                            <div class="stat-text">Total Orders</div>
                            <div class="stat-digit"><i class="fa fa-shopping-cart"></i> @Model.TotalOrders</div>
                        </div>
                        <div class="progress">
                            <div class="progress-bar progress-bar-warning w-100" role="progressbar" aria-valuenow="100" aria-valuemin="0" aria-valuemax="100"></div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-lg-3 col-sm-6">
                <div class="card">
                    <div class="stat-widget-two card-body">
                        <div class="stat-content">
                            <div class="stat-text">Total Revenue</div>
                            <div class="stat-digit"><i class="fa fa-usd"></i> @Model.TotalRevenue</div>
                        </div>
                        <div class="progress">
                            <div class="progress-bar progress-bar-danger w-100" role="progressbar" aria-valuenow="100" aria-valuemin="0" aria-valuemax="100"></div>
                        </div>
                    </div>
                </div>
                <!-- /# card -->
            </div>
            <!-- /# column -->
        </div>

        <!-- Order status breakdown + Low stock -->
        <div class="row">
            <div class="col-xl-8 col-lg-8 col-md-8">
                <div class="card">
                    <div class="card-header">
                        <h4 class="card-title">Order Status Overview</h4>
                    </div>
                    <div class="card-body">
                        @{
                            int total = Model.TotalOrders == 0 ? 1 : Model.TotalOrders;
                            int pendingPct = Model.PendingOrders * 100 / total;
                            int processingPct = Model.ProcessingOrders * 100 / total;
                            int deliveredPct = Model.DeliveredOrders * 100 / total;
                            int cancelledPct = Model.CancelledOrders * 100 / total;
                        }
                        <div class="current-progress">
                            <div class="progress-content py-2">
                                <div class="row">
                                    <div class="col-lg-3">
                                        <div class="progress-text">Pending (@Model.PendingOrders)</div>
                                    </div>
                                    <div class="col-lg-9">
                                        <div class="current-progressbar">
                                            <div class="progress">
                                                <div class="progress-bar progress-bar-warning" role="progressbar" style="width:@(pendingPct)%" aria-valuenow="@pendingPct" aria-valuemin="0" aria-valuemax="100">
                                                    @pendingPct%
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="progress-content py-2">
                                <div class="row">
                                    <div class="col-lg-3">
                                        <div class="progress-text">Processing (@Model.ProcessingOrders)</div>
                                    </div>
                                    <div class="col-lg-9">
                                        <div class="current-progressbar">
                                            <div class="progress">
                                                <div class="progress-bar progress-bar-primary" role="progressbar" style="width:@(processingPct)%" aria-valuenow="@processingPct" aria-valuemin="0" aria-valuemax="100">
                                                    @processingPct%
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="progress-content py-2">
                                <div class="row">
                                    <div class="col-lg-3">
                                        <div class="progress-text">Delivered (@Model.DeliveredOrders)</div>
                                    </div>
                                    <div class="col-lg-9">
                                        <div class="current-progressbar">
                                            <div class="progress">
                                                <div class="progress-bar progress-bar-success" role="progressbar" style="width:@(deliveredPct)%" aria-valuenow="@deliveredPct" aria-valuemin="0" aria-valuemax="100">
                                                    @deliveredPct%
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="progress-content py-2">
                                <div class="row">
                                    <div class="col-lg-3">
                                        <div class="progress-text">Cancelled (@Model.CancelledOrders)</div>
                                    </div>
                                    <div class="col-lg-9">
                                        <div class="current-progressbar">
                                            <div class="progress">
                                                <div class="progress-bar progress-bar-danger" role="progressbar" style="width:@(cancelledPct)%" aria-valuenow="@cancelledPct" aria-valuemin="0" aria-valuemax="100">
                                                    @cancelledPct%
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-xl-4 col-lg-4 col-md-4">
                <div class="card">
                    <div class="card-header">
                        <h4 class="card-title">Low Stock Books</h4>
                    </div>
                    <div class="card-body">
                        @if (!Model.LowStockBooks.Any())
                        {
                            <p class="text-muted mb-0">All books are well stocked.</p>
                        }
                        else
                        {
                            <ul class="list-unstyled mb-0">
                                @foreach (var book in Model.LowStockBooks)
                                {
                                    <li class="d-flex justify-content-between align-items-center py-2 border-bottom">
                                        <span>@book.BookName</span>
                                        <span class="badge @(book.quantity == 0 ? "badge-danger" : "badge-warning")">
                                            @book.quantity left
                                        </span>
                                    </li>
                                }
                            </ul>
                        }
                    </div>
                </div>
            </div>
        </div>

        <!-- Recent Orders -->
        <div class="row">
            <div class="col-lg-12">
                <div class="card">
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <h4 class="card-title">Recent Orders</h4>
                        <a asp-action="Orders" asp-controller="Admin" class="btn btn-sm btn-primary">View All</a>
                    </div>
                    <div class="card-body">
                        <div class="table-responsive">
                            <table class="table mb-0">
                                <thead>
                                    <tr>
                                        <th>Order #</th>
                                        <th>Customer</th>
                                        <th>Items</th>
                                        <th>Total</th>
                                        <th>Status</th>
                                        <th>Date</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @if (!Model.RecentOrders.Any())
                                    {
                                        <tr>
                                            <td colspan="6" class="text-center text-muted">No orders placed yet.</td>
                                        </tr>
                                    }
                                    else
                                    {
                                        @foreach (var order in Model.RecentOrders)
                                        {
                                            string badgeClass = order.OrderStatus.ToLower() switch
                                            {
                                                "delivered" => "badge-success",
                                                "cancelled" => "badge-danger",
                                                "processing" => "badge-info",
                                                _ => "badge-warning"
                                            };
                                            <tr>
                                                <td>#@order.OrderId.ToString("D5")</td>
                                                <td>@order.FullName</td>
                                                <td>@order.OrderItems.Count</td>
                                                <td>Rs.@order.TotalAmount</td>
                                                <td><span class="badge @badgeClass">@order.OrderStatus</span></td>
                                                <td>@order.CreatedAt.ToString("dd-MMM-yy")</td>
                                            </tr>
                                        }
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>

    </div>
</div>
<!--**********************************
    Content body end
***********************************-->
