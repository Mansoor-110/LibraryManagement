@model LibraryManagement.Models.LibrarianDashboardVM

@{
    Layout = "~/views/shared/_librarianLayout.cshtml";
}
<!--**********************************
    Content body start
***********************************-->
<div class="content-body">
    <div class="container-fluid">

        <!-- Top stat cards -->
        <div class="row">
            <div class="col-lg-3 col-sm-6">
                <div class="card">
                    <div class="stat-widget-two card-body">
                        <div class="stat-content">
                            <div class="stat-text">Pending Requests</div>
                            <div class="stat-digit"><i class="fa fa-clock-o"></i> @Model.PendingRequests</div>
                        </div>
                        <div class="progress">
                            <div class="progress-bar progress-bar-warning w-100" role="progressbar" aria-valuenow="100" aria-valuemin="0" aria-valuemax="100"></div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-lg-3 col-sm-6">
                <div class="card">
                    <div class="stat-widget-two card-body">
                        <div class="stat-content">
                            <div class="stat-text">Issued Books</div>
                            <div class="stat-digit"><i class="fa fa-book"></i> @Model.TotalIssuedBooks</div>
                        </div>
                        <div class="progress">
                            <div class="progress-bar progress-bar-primary w-100" role="progressbar" aria-valuenow="100" aria-valuemin="0" aria-valuemax="100"></div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-lg-3 col-sm-6">
                <div class="card">
                    <div class="stat-widget-two card-body">
                        <div class="stat-content">
                            <div class="stat-text">Overdue Books</div>
                            <div class="stat-digit"><i class="fa fa-exclamation-triangle"></i> @Model.OverdueBooks</div>
                        </div>
                        <div class="progress">
                            <div class="progress-bar progress-bar-danger w-100" role="progressbar" aria-valuenow="100" aria-valuemin="0" aria-valuemax="100"></div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-lg-3 col-sm-6">
                <div class="card">
                    <div class="stat-widget-two card-body">
                        <div class="stat-content">
                            <div class="stat-text">Outstanding Fine</div>
                            <div class="stat-digit"><i class="fa fa-usd"></i> @Model.TotalOutstandingFine</div>
                        </div>
                        <div class="progress">
                            <div class="progress-bar progress-bar-success w-100" role="progressbar" aria-valuenow="100" aria-valuemin="0" aria-valuemax="100"></div>
                        </div>
                    </div>
                </div>
                <!-- /# card -->
            </div>
            <!-- /# column -->
        </div>

        <!-- Borrow request breakdown + Low stock for borrow -->
        <div class="row">
            <div class="col-xl-8 col-lg-8 col-md-8">
                <div class="card">
                    <div class="card-header">
                        <h4 class="card-title">Borrow Request Status</h4>
                    </div>
                    <div class="card-body">
                        @{
                            int total = Model.TotalBorrowRequests == 0 ? 1 : Model.TotalBorrowRequests;
                            int pendingPct = Model.PendingRequests * 100 / total;
                            int approvedPct = Model.ApprovedRequests * 100 / total;
                            int rejectedPct = Model.RejectedRequests * 100 / total;
                        }
                        <div class="current-progress">
                            <div class="progress-content py-2">
                                <div class="row">
                                    <div class="col-lg-3">
                                        <div class="progress-text">Pending (@Model.PendingRequests)</div>
                                    </div>
                                    <div class="col-lg-9">
                                        <div class="current-progressbar">
                                            <div class="progress">
                                                <div class="progress-bar progress-bar-warning" role="progressbar" style="width:@(pendingPct)%" aria-valuenow="@pendingPct" aria-valuemin="0" aria-valuemax="100">
                                                    @pendingPct%
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="progress-content py-2">
                                <div class="row">
                                    <div class="col-lg-3">
                                        <div class="progress-text">Approved (@Model.ApprovedRequests)</div>
                                    </div>
                                    <div class="col-lg-9">
                                        <div class="current-progressbar">
                                            <div class="progress">
                                                <div class="progress-bar progress-bar-success" role="progressbar" style="width:@(approvedPct)%" aria-valuenow="@approvedPct" aria-valuemin="0" aria-valuemax="100">
                                                    @approvedPct%
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="progress-content py-2">
                                <div class="row">
                                    <div class="col-lg-3">
                                        <div class="progress-text">Rejected (@Model.RejectedRequests)</div>
                                    </div>
                                    <div class="col-lg-9">
                                        <div class="current-progressbar">
                                            <div class="progress">
                                                <div class="progress-bar progress-bar-danger" role="progressbar" style="width:@(rejectedPct)%" aria-valuenow="@rejectedPct" aria-valuemin="0" aria-valuemax="100">
                                                    @rejectedPct%
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-xl-4 col-lg-4 col-md-4">
                <div class="card">
                    <div class="card-header">
                        <h4 class="card-title">Low Borrow Stock</h4>
                    </div>
                    <div class="card-body">
                        @if (!Model.LowBorrowStockBooks.Any())
                        {
                            <p class="text-muted mb-0">All books have healthy borrow stock.</p>
                        }
                        else
                        {
                            <ul class="list-unstyled mb-0">
                                @foreach (var book in Model.LowBorrowStockBooks)
                                {
                                    <li class="d-flex justify-content-between align-items-center py-2 border-bottom">
                                        <span>@book.BookName</span>
                                        <span class="badge @(book.qtyforborrow == 0 ? "badge-danger" : "badge-warning")">
                                            @book.qtyforborrow left
                                        </span>
                                    </li>
                                }
                            </ul>
                        }
                    </div>
                </div>
            </div>
        </div>

        <!-- Recent Borrow Requests -->
        <div class="row">
            <div class="col-lg-12">
                <div class="card">
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <h4 class="card-title">Recent Borrow Requests</h4>
                        <a asp-action="BorrowRequests" asp-controller="Librarian" class="btn btn-sm btn-primary">View All</a>
                    </div>
                    <div class="card-body">
                        <div class="table-responsive">
                            <table class="table mb-0">
                                <thead>
                                    <tr>
                                        <th>Book</th>
                                        <th>Requested By</th>
                                        <th>Email</th>
                                        <th>Requested On</th>
                                        <th>Status</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @if (!Model.RecentBorrowRequests.Any())
                                    {
                                        <tr>
                                            <td colspan="5" class="text-center text-muted">No borrow requests yet.</td>
                                        </tr>
                                    }
                                    else
                                    {
                                        @foreach (var item in Model.RecentBorrowRequests)
                                        {
                                            string badgeClass = item.Status.ToLower() switch
                                            {
                                                "approved" => "badge-success",
                                                "rejected" => "badge-danger",
                                                _ => "badge-warning"
                                            };
                                            <tr>
                                                <td>@item.BookName</td>
                                                <td>@item.User_name</td>
                                                <td>@item.Email</td>
                                                <td>@item.CreatedAt.ToString("dd-MMM-yy")</td>
                                                <td><span class="badge @badgeClass">@item.Status</span></td>
                                            </tr>
                                        }
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Recent Issued Books -->
        <div class="row">
            <div class="col-lg-12">
                <div class="card">
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <h4 class="card-title">Recent Issued Books</h4>
                        <a asp-action="IssuedBook" asp-controller="Librarian" class="btn btn-sm btn-primary">View All</a>
                    </div>
                    <div class="card-body">
                        <div class="table-responsive">
                            <table class="table mb-0">
                                <thead>
                                    <tr>
                                        <th>Book</th>
                                        <th>Issued To</th>
                                        <th>Issued Date</th>
                                        <th>Return Date</th>
                                        <th>Fine</th>
                                        <th>Status</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @if (!Model.RecentIssuedBooks.Any())
                                    {
                                        <tr>
                                            <td colspan="6" class="text-center text-muted">No books issued yet.</td>
                                        </tr>
                                    }
                                    else
                                    {
                                        @foreach (var item in Model.RecentIssuedBooks)
                                        {
                                            string badgeClass = item.status.ToLower() switch
                                            {
                                                "returned" => "badge-success",
                                                "overdue" => "badge-danger",
                                                _ => "badge-warning"
                                            };
                                            <tr>
                                                <td>@item.BookName</td>
                                                <td>@item.User_name</td>
                                                <td>@item.issuedDate.ToString("dd-MMM-yy")</td>
                                                <td>@item.returnDate.ToString("dd-MMM-yy")</td>
                                                <td>
                                                    @if (item.fineAmount > 0)
                                                    {
                                                        <span class="text-danger fw-bold">Rs.@item.fineAmount</span>
                                                    }
                                                    else
                                                    {
                                                        <span>Rs.0</span>
                                                    }
                                                </td>
                                                <td><span class="badge @badgeClass">@item.status</span></td>
                                            </tr>
                                        }
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>

    </div>
</div>
<!--**********************************
    Content body end
***********************************-->
