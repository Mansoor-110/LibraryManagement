@model List<LibraryManagement.Models.BorrowRequestVM>
@{
    Layout = "~/views/shared/_librarianLayout.cshtml";
}

<!--**********************************
           Content body start
       ***********************************-->
       <style>
    :root {
        --teal: #1cb8ba;
        --teal-dark: #149193;
        --teal-tint: #eafcfc;
        --navy: #14213d;
        --gray: #6f7c8e;
        --amber: #f2994a;
        --amber-tint: #fff4e8;
        --red: #e0575b;
        --red-tint: #fdeceb;
        --radius: 10px;
        --shadow: 0 10px 30px rgba(20,33,61,0.08);
    }
    .badge-pill {
        display: inline-block;
        font-size: 12px;
        font-weight: 600;
        padding: 5px 14px;
        border-radius: 20px;
    }
    .badge-pending {
        background: var(--amber-tint);
        color: var(--amber);
    }

    .badge-approved {
        background: var(--teal-tint);
        color: var(--teal-dark);
    }

    .badge-rejected {
        background: var(--red-tint);
        color: var(--red);
    }

    .badge-ontime {
        background: var(--teal-tint);
        color: var(--teal-dark);
    }

    .badge-late {
        background: var(--red-tint);
        color: var(--red);
    }
       </style>
<div class="content-body">
    <div class="container-fluid">
        <div class="row page-titles mx-0">
            <div class="col-sm-6 p-md-0">
                <div class="welcome-text">
                    <h4>Hi, welcome back!</h4>
                    <p class="mb-0">Your business dashboard template</p>
                </div>
            </div>
            <div class="col-sm-6 p-md-0 justify-content-sm-end mt-2 mt-sm-0 d-flex">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="javascript:void(0)">Table</a></li>
                    <li class="breadcrumb-item active"><a href="javascript:void(0)">Bootstrap</a></li>
                </ol>
            </div>
        </div>
        <!-- row -->

        <div class="row">
            <div class="col-lg-12">
                <div class="card">
                    <div class="card-header">
                        <h4 class="card-title">Requests</h4>
                    </div>
                    <div class="card-body">
                        <div class="table-responsive">
                            <table class="table primary-table-bordered table-responsive-sm text-muted">
                                <thead class="thead-primary">
                                    <tr class="text-primary">
                                        <th width="60px">Request Id</th>
                                        <th width="120px">Book Image</th>
                                        <th width="150px">Book Name</th>
                                        <th width="200px">Requested By</th>
                                        <th width="90px">Status</th>
                                        <th width="70px">Qty For Borrow</th>
                                        <th width="110px">Request Date</th>
                                        <th width="80px">Action</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in Model)
                                    {
                                        <tr>
                                            <td>@item.borrowRequestid</td>
                                            <td><img src="~/BookImages/@item.BookImageName" width="100" /></td>
                                            <td>@item.BookName</td>
                                            <td>
                                                <span class="font-weight-bold">Name:</span> @item.User_name <br>
                                                <span class="font-weight-bold">Email:</span> @item.Email
                                            </td>
                                            @if (item.Status == "Pending")
                                            {
                                                <td><span class="badge-pill badge-pending">@item.Status</span></td>
                                            }else if(item.Status == "Approved")
                                            {
                                                <td><span class="badge-pill badge-approved">@item.Status</span></td>

                                            }
                                            else
                                            {
                                                <td><span class="badge-pill badge-rejected">@item.Status</span></td>
                                            }
                                            <td>@item.qtyforborrow</td>
                                            <td>@item.CreatedAt.ToString("dd-MMMM-yy")</td>
                                            <td>
                                                @if (item.Status == "Pending" && item.qtyforborrow == 0) {




                                                    <span class="font-weight-bold"> Not-Available</span>
                                                    <a asp-action="RejectRequest" asp-controller="Librarian" asp-route-id="@item.borrowRequestid" class="btn btn-danger" style="width: 90px;">Reject </a>


                                                } else if (item.Status == "Pending"){

                                                    <a asp-action="ApproveRequest" asp-controller="Librarian" asp-route-id="@item.borrowRequestid" class="btn btn-outline-success mb-2" style="width: 90px;">Approve</a>

                                                    <a asp-action="RejectRequest" asp-controller="Librarian" asp-route-id="@item.borrowRequestid" class="btn btn-danger" style="width: 90px;">Reject </a>
                                                } 
                                                
                                                 

                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
<!--**********************************
    Content body end
***********************************-->
