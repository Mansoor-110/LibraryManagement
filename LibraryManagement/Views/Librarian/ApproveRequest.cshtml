@model LibraryManagement.Models.IssuedBook;


@{
    Layout = "~/views/shared/_librarianLayout.cshtml";
}
<!--**********************************
           Content body start
       ***********************************-->
<div class="content-body">
    <div class="container-fluid">
        <div class="row page-titles mx-0">
            <div class="col-sm-6 p-md-0">
                <div class="welcome-text">
                    <h4>Hi, welcome back!</h4>
                    <p class="mb-0">Your business dashboard template</p>
                </div>
            </div>
            <div class="col-sm-6 p-md-0 justify-content-sm-end mt-2 mt-sm-0 d-flex">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="javascript:void(0)">Table</a></li>
                    <li class="breadcrumb-item active"><a href="javascript:void(0)">Bootstrap</a></li>
                </ol>
            </div>
        </div>
        <!-- row -->

        <div class="row">
            <div class="col-lg-12">
                <div class="card">
                    <div class="card-header">
                        <h4 class="card-title">Approve Request</h4>
                    </div>
                    <div class="card-body text-muted">
                        <form asp-action="ApproveRequest" asp-controller="Librarian" method="post">
                            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                            <div class="form-group">
                                <label asp-for=" issuedDate" class="control-label"></label>
                                <input type="date" asp-for="issuedDate" class="form-control" />
                                <span asp-validation-for="issuedDate" class="text-danger"></span>
                            </div>
                            <div class="form-group">
                                <label asp-for=" returnDate" class="control-label"></label>
                                <input type="date" asp-for="returnDate" class="form-control" />
                                <span asp-validation-for="returnDate" class="text-danger"></span>
                            </div>
                                                      
                           <div class="form-group">
                                <input type="submit" value="Approve" class="btn btn-primary" />
                            </div>
                        </form>

                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
<!--**********************************
    Content body end
***********************************-->
